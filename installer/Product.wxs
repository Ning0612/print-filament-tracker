<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 安裝程式定義 - Filament Ledger（材料帳本）
  建置由 scripts\build_exe.ps1 自動呼叫
  外部變數：Version, ExeSource, IconSource
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!-- UpgradeCode 沿用舊值：Windows 以此判定「同一產品升級」，改動會被視為
       全新產品而無法自動移除/覆蓋舊版。改名後仍須保留以支援無痛升級。 -->
  <Package
    Name="Filament Ledger"
    Manufacturer="Ning0612"
    Version="$(var.Version).0"
    UpgradeCode="F7A2B3C4-E5D6-4870-9192-A3B4C5D6E7F8"
    Codepage="950"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- 程式圖示：顯示於「程式和功能」清單及安裝精靈 -->
    <Icon Id="AppIcon" SourceFile="$(var.IconSource)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Ning0612/filament-ledger" />

    <!-- 安裝精靈使用者介面 -->
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)license.rtf" />
    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- 完成畫面：立即啟動選項（預設勾選） -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Filament Ledger" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <!-- 安裝完成後啟動應用程式 -->
    <CustomAction Id="LaunchApp"
                  FileRef="MainExeFile"
                  ExeCommand=""
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <!-- 功能清單 -->
    <Feature Id="Main" Title="Main application" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="DesktopShortcutFeature"
             Title="Desktop shortcut"
             Description="Create a Filament Ledger shortcut on the desktop"
             Level="1">
      <ComponentRef Id="DesktopShortcutComp" />
    </Feature>
  </Package>

  <!-- 目錄結構 -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Filament Ledger" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="Filament Ledger" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <!-- 元件定義 -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Guid="*">
        <File Id="MainExeFile" Source="$(var.ExeSource)" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Component Id="StartMenuShortcut" Directory="AppMenuFolder" Guid="*">
      <Shortcut Id="AppShortcut"
                Name="Filament Ledger"
                Description="Filament management tool"
                Target="[INSTALLFOLDER]FilamentLedger.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="CleanupMenu" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue Root="HKLM"
                     Key="Software\Ning0612\PrintFilamentTracker"
                     Name="installed" Type="integer" Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcutComp" Directory="DesktopFolder" Guid="*">
      <Shortcut Id="DesktopShortcut"
                Name="Filament Ledger"
                Description="Filament management tool"
                Target="[INSTALLFOLDER]FilamentLedger.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKLM"
                     Key="Software\Ning0612\PrintFilamentTracker"
                     Name="desktop" Type="integer" Value="1"
                     KeyPath="yes" />
    </Component>
  </Fragment>

  <!-- 完成畫面按鈕事件：觸發啟動動作 -->
  <Fragment>
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApp" Order="1"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>
  </Fragment>

</Wix>
