# Bambu Lab Cloud Access Token
# 取得方式：透過 POST https://api.bambulab.com/v1/user-service/user/login
BAMBU_ACCESS_TOKEN=

# 區域設定：global（預設）或 china
BAMBU_REGION=global

# API Base URL（若設定則覆寫 BAMBU_REGION 推導的值）
# BAMBU_API_BASE=https://api.bambulab.com

# Web 伺服器 Port（預設 7580，修改後需重啟生效）
# 若 7580 與本機其他服務衝突，可改為其他未使用的 port（建議 1024–65535）。
PORT=7580
